{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.git",
      "!**/.next",
      "!**/node_modules",
      "!**/storybook-static",
      "!drizzle/meta",
      "!package-lock.json",
      "!tmp",
      "!tsconfig.tsbuildinfo"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  }
}
